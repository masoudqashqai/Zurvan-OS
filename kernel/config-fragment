# Zurvan kernel config fragment — the must-have symbols for the QEMU/initramfs path.
#
# This is NOT a full kernel config. It is the small set of options that the boot
# chain depends on. The workflow is:
#
#   1. make defconfig            # sane x86_64 baseline
#   2. merge this fragment in    # ensure our essentials are set
#   3. make menuconfig           # eyeball it / trim later
#
# build.sh applies this via scripts/kconfig/merge_config.sh when present.

# --- initramfs: unpack our cpio.gz into RAM and run /init --------------------
CONFIG_BLK_DEV_INITRD=y

# --- serial console: makes `qemu -nographic` usable (console=ttyS0) ----------
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_TTY=y
CONFIG_PRINTK=y

# --- /dev populated by the kernel -------------------------------------------
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- virtio: networking (and friends) under QEMU ----------------------------
CONFIG_PCI=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y

# --- block devices: the persistent /data disk (v2 milestone 1) ---------------
# libata exposes SATA/IDE disks as SCSI disks (/dev/sdX), so SCSI + SD come too.
CONFIG_BLOCK=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
# legacy IDE controller: plain `qemu -hda` and VMware IDE
CONFIG_ATA_PIIX=y
# virtio-blk: QEMU/KVM disks attached with -drive if=virtio (/dev/vdX)
CONFIG_VIRTIO_BLK=y
# VMware's default SCSI controllers for Linux guests: LSI Logic (mptspi) and
# PVSCSI — without these a VMware disk on the default controller is invisible.
CONFIG_FUSION=y
CONFIG_FUSION_SPI=y
CONFIG_VMWARE_PVSCSI=y

# --- CD-ROM + iso9660: zurvan-install mounts the boot CD to copy the image ---
# (already =y in defconfig; pinned here because the install path depends on it)
CONFIG_BLK_DEV_SR=y
CONFIG_ISO9660_FS=y
CONFIG_JOLIET=y

# --- partition tables: zurvan-install writes MBR; GPT costs nothing ----------
CONFIG_MSDOS_PARTITION=y
CONFIG_EFI_PARTITION=y

# --- ext4: the /data filesystem ----------------------------------------------
CONFIG_EXT4_FS=y

# --- filesystems used by the rootfs / overlay stretch goal ------------------
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
# OVERLAY_FS is for the immutable-root stretch goal; harmless to enable early.
CONFIG_OVERLAY_FS=y

# --- 64-bit ELF binaries (busybox, bash, our init) --------------------------
CONFIG_BINFMT_ELF=y

# --- hardening baseline (v2 milestone 3, "the seal") -------------------------
# Today's table stakes for a server kernel. Each is one symbol to review.
# Memory-corruption mitigations:
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_RANDOMIZE_BASE=y            # KASLR
CONFIG_RANDOMIZE_MEMORY=y
# Shrink the attack surface / close info leaks:
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_MODULE_RWX=y
CONFIG_DEVMEM=n                    # no /dev/mem window into RAM
CONFIG_DEVKMEM=n
CONFIG_SECURITY_DMESG_RESTRICT=y   # non-root can't read the kernel log
CONFIG_LEGACY_PTYS=n
# No loadable modules AT ALL — everything Zurvan needs is built in, so the
# module-loading attack surface simply does not exist. (Belt for the seal:
# a signed kernel that can't load an unsigned module at runtime.)
CONFIG_MODULES=n
