# Build artifacts — everything here is regenerated by the build scripts.
/build/
*.cpio.gz
*.cpio

# Kernel build tree and downloads
kernel/build/
kernel/src/
kernel/*.tar.*
kernel/linux-*/

# Userland sources and build trees
userland/build/
userland/src/
userland/busybox-*/
userland/bash-*/
userland/*.tar.*

# Compiled init + supervisor
init/init
init/*.o
svc/zurvan-svc
svc/*.o

# Image-signing keys (v2 M3 "the seal") — NEVER commit the private key.
# scripts/make-keys.sh regenerates the pair; losing it only means re-keying
# your boxes with a new install.
/keys/

# Editor / OS noise
*.swp
*~
.DS_Store
