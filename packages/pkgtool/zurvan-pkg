#!/bin/sh
# zurvan-pkg — install, remove, list, and "dress" Zurvan packages.
#
# A package is a gzipped tarball of STATIC binaries plus one manifest.yaml,
# built by catalog/build-<name>.sh. Because nothing is dynamically linked,
# install is just: verify the package's detached signature (gpgv against
# /etc/zurvan-signing.pub — the same check zurvan-upgrade runs on images;
# --unsigned skips it, loudly), unpack into /data/apps/<name>/, and plant
# symlinks.
#
# The set-dresser trick: programs expect /usr/bin, /var/lib, /etc — and the
# RAM root is freely writable — so the standard paths are symlinks into /data,
# rebuilt from the manifests on every boot (`zurvan-pkg dress`, called by
# rc.init) and immediately on install. They can never rot: the RAM root is
# reborn each boot and re-dressed from scratch.
#
#   /data/apps/<name>/   the unpacked package (owned by zurvan-pkg, replaced
#                        wholesale on upgrade)
#   /data/srv/<name>/    the app's persistent state (never touched by remove)
#
# Dependencies are deliberately shallow: `needs:` names other packages that
# must already be installed. One loop, no versions, no graphs — if this ever
# wants to be cleverer, stop (see ROADMAP.md).
#
# Manifest (same tiny YAML dialect as the provisioner):
#   name: hello
#   version: "1.0"
#   needs:
#     - openssl
#   links:                             # -> path inside /data/apps/<name>/
#     - /usr/bin/hello -> bin/hello
#   state_links:                       # -> path inside /data/srv/<name>/
#     - /var/lib/hello -> .
#   service:                           # exported to /run/svc/<name>.def for
#     exec: /usr/bin/hellod            # zurvan-svc (v2 M2); enable it by adding
#     after:                           # the package name to services: in the
#       - networking                   # YAML
#     restart: yes
set -eu

APPS=/data/apps
SRV=/data/srv

log()  { echo "[pkg] $*"; }
fail() { echo "[pkg] ERROR: $*" >&2; exit 1; }

need_data() {
	mountpoint -q /data 2>/dev/null \
		|| fail "/data is not mounted — packages need the persistent disk (see zurvan-install)"
}

# The seal (v2 M3) leaves / read-only. Installing plants symlinks in /usr/bin,
# /var/lib, ... — on the RAM root — so we briefly reopen / for writing and
# reseal on the way out (including on error). root_was_ro remembers whether we
# actually flipped it, so an already-writable root (zurvan.rw) is left alone.
root_was_ro=0
open_root() {
	if grep -qE ' / [^ ]+ ro[, ]' /proc/mounts; then
		mount -o remount,rw / 2>/dev/null && root_was_ro=1
	fi
}
seal_root() {
	[ "$root_was_ro" = 1 ] && mount -o remount,ro / 2>/dev/null || true
}

# --- manifest access -----------------------------------------------------------
# yaml_scalar KEY FILE  -> value of a top-level "key: value"
# yaml_list   KEY FILE  -> the "  - item" entries under a top-level "key:"
yaml_scalar() {
	awk -v k="$1:" '$1 == k { sub(/^[^:]*:[ \t]*/, ""); gsub(/^"|"$/, ""); print; exit }' "$2"
}
yaml_list() {
	awk -v k="$1" '
		/^[^ \t]/ { ink = ($0 ~ "^" k ":") ; next }
		ink && /^[ \t]+- / { sub(/^[ \t]+- [ \t]*/, ""); print }
	' "$2"
}

# --- service export -----------------------------------------------------------
# svc_scalar KEY FILE / svc_after FILE read inside the top-level service: block.
# The digested flat .def is all zurvan-svc ever sees — the C supervisor parses
# no YAML (one YAML parser per operating system is plenty).
svc_scalar() {
	awk -v k="$1:" '
		/^service:/  { s = 1; next }
		/^[^ \t]/    { s = 0 }
		s && $1 == k { sub(/^[ \t]*[^:]*:[ \t]*/, ""); gsub(/^"|"$/, ""); print; exit }
	' "$2"
}
svc_after() {
	awk '
		/^service:/           { s = 1; next }
		/^[^ \t]/             { s = 0; a = 0 }
		s && $1 == "after:"   { a = 1; next }
		s && a && /^[ \t]+- / { sub(/^[ \t]+- [ \t]*/, ""); out = out $0 " "; next }
		s && /^[ \t]+[^- \t]/ { a = 0 }
		END                   { sub(/ $/, "", out); print out }
	' "$1"
}

export_service() {
	name="$1"
	man="$APPS/$name/manifest.yaml"
	[ -f "$man" ] || return 0
	ex="$(svc_scalar exec "$man")"
	[ -n "$ex" ] || return 0
	mkdir -p /run/svc
	usr="$(svc_scalar user "$man")"
	{
		echo "exec=$ex"
		aft="$(svc_after "$man")"
		[ -n "$aft" ] && echo "after=$aft"
		[ -n "$usr" ] && echo "user=$usr"
		r="$(svc_scalar restart "$man")"
		echo "restart=${r:-yes}"
	} > "/run/svc/$name.def"
	# A service dropping to a non-root user must own its persistent state, or
	# it can't write it. The state dir is on /data (writable); chown it here.
	[ -n "$usr" ] && [ -d "$SRV/$name" ] && chown -R "$usr" "$SRV/$name" 2>/dev/null || true
}

# --- linking ---------------------------------------------------------------------
# Each entry is "<absolute path> -> <relative target>". links: resolve inside
# /data/apps/<name>/, state_links: inside /data/srv/<name>/. The link lives on
# the RAM root, so replacing whatever the image put there is fair game; the
# /data side is only ever pointed AT, never deleted here.
plant_list() {
	name="$1"; key="$2"; base="$3"
	man="$APPS/$name/manifest.yaml"
	[ -f "$man" ] || return 0
	yaml_list "$key" "$man" | while IFS= read -r entry; do
		linkpath="${entry%% -> *}"
		target="${entry##* -> }"
		case "$linkpath" in /?*) ;; *) linkpath="" ;; esac
		[ -n "$linkpath" ] && [ -n "$target" ] && [ "$linkpath" != "$entry" ] \
			|| { log "WARNING: $name: bad $key entry '$entry' (want '/abs/path -> rel/path')"; continue; }
		[ -e "$base/$target" ] \
			|| log "WARNING: $name: $key target $target missing under $base"
		mkdir -p "$(dirname "$linkpath")"
		# an image-provided dir (e.g. an empty /var/lib/hello) yields to the link
		[ ! -e "$linkpath" ] || [ -L "$linkpath" ] || rm -rf "$linkpath"
		rm -f "$linkpath"
		ln -s "$base/$target" "$linkpath"
	done
}

plant_links() {
	plant_list "$1" links "$APPS/$1"
	plant_list "$1" state_links "$SRV/$1"
}

remove_list() {
	name="$1"; key="$2"
	man="$APPS/$name/manifest.yaml"
	[ -f "$man" ] || return 0
	yaml_list "$key" "$man" | while IFS= read -r entry; do
		linkpath="${entry%% -> *}"
		[ -n "$linkpath" ] && [ "$linkpath" != "$entry" ] && rm -f "$linkpath"
	done
}

remove_links() {
	remove_list "$1" links
	remove_list "$1" state_links
}

# seal_root runs on the way out however we leave (success, fail, or signal),
# so a package operation can never strand the root writable.
trap seal_root EXIT INT TERM

# --- commands ---------------------------------------------------------------------
cmd_install() {
	need_data
	tarball="$1"; unsigned="${2:-0}"
	[ -f "$tarball" ] || fail "no such file: $tarball"

	# The seal's promise extends to packages: verify the detached signature
	# BEFORE unpacking, with the same gpgv + trust anchor that gates image
	# upgrades. Catalog packages ship a .sig beside the tarball (the installer
	# copies both to /data; the catalog pack carries one per package). A
	# package you built yourself has no Zurvan signature — say so explicitly:
	#     zurvan-pkg install --unsigned <pkg.tar.gz>
	if [ "$unsigned" = 1 ]; then
		log "WARNING: installing UNSIGNED package (--unsigned): $tarball"
	else
		pub=/etc/zurvan-signing.pub
		command -v gpgv >/dev/null 2>&1 \
			|| fail "gpgv missing from this image — cannot verify $(basename "$tarball") (--unsigned to override)"
		[ -f "$pub" ] || fail "no trust anchor at $pub — cannot verify (--unsigned to override)"
		[ -f "$tarball.sig" ] \
			|| fail "no signature: $(basename "$tarball").sig not found beside the package — copy the .sig too, or use --unsigned for a package you built yourself"
		gpgv --keyring "$pub" "$tarball.sig" "$tarball" 2>/dev/null \
			|| fail "signature check FAILED for $(basename "$tarball") — tampered, unsigned, or wrong key; refusing to unpack"
		log "signature OK: $(basename "$tarball")"
	fi

	open_root

	# Unpack somewhere disposable first; trust the manifest, not the filename.
	tmp="$APPS/.install.$$"
	rm -rf "$tmp"; mkdir -p "$tmp"
	tar -xzf "$tarball" -C "$tmp" || { rm -rf "$tmp"; fail "cannot unpack $tarball"; }
	[ -f "$tmp/manifest.yaml" ] || { rm -rf "$tmp"; fail "$tarball has no manifest.yaml"; }

	name="$(yaml_scalar name "$tmp/manifest.yaml")"
	version="$(yaml_scalar version "$tmp/manifest.yaml")"
	[ -n "$name" ] || { rm -rf "$tmp"; fail "manifest has no name:"; }

	# Shallow dependency check — the whole resolver, on purpose.
	missing=""
	for dep in $(yaml_list needs "$tmp/manifest.yaml"); do
		[ -d "$APPS/$dep" ] || missing="$missing $dep"
	done
	[ -z "$missing" ] || { rm -rf "$tmp"; fail "$name needs:$missing — install those first"; }

	# Upgrade = replace the app dir wholesale. State in /data/srv survives.
	if [ -d "$APPS/$name" ]; then
		log "replacing installed $name"
		remove_links "$name"
		rm -rf "$APPS/$name"
	fi
	mv "$tmp" "$APPS/$name"
	mkdir -p "$SRV/$name"

	# Dress immediately so a fresh install works without a reboot.
	plant_links "$name"
	export_service "$name"
	log "installed $name${version:+ $version} -> $APPS/$name (state: $SRV/$name)"
	# `if`, not `A && B`: a non-service package has no .def, and a trailing
	# false test would make cmd_install (and the whole script) exit 1 on a
	# perfectly good install — which breaks `install && do-next` callers.
	if [ -f "/run/svc/$name.def" ]; then
		log "service definition exported — add '$name' to services: in the YAML to enable it"
	fi
}

# Enable an installed SERVICE package: make it part of what this box runs.
# Two representations, kept in step: the YAML services: list (the authored,
# reproducible source of truth) AND /run/svc/enabled (the digest the running
# supervisor rescans each heartbeat, so it starts now without a reboot).
# Non-service packages are refused here — they have nothing to enable.
cmd_enable() {
	need_data
	name="$1"
	[ -d "$APPS/$name" ] || fail "$name is not installed"
	[ -f "/run/svc/$name.def" ] \
		|| fail "$name is not a service (its manifest has no service: block) — nothing to enable"

	yaml=/data/zurvan.yaml
	if [ -f "$yaml" ] && grep -qE "^[[:space:]]*-[[:space:]]+$name[[:space:]]*$" "$yaml"; then
		: # already declared
	elif [ -f "$yaml" ] && grep -qE "^services:" "$yaml"; then
		# insert as the first entry under the existing services: block
		awk -v n="$name" '
			{ print }
			/^services:/ && !done { print "  - " n; done = 1 }
		' "$yaml" > "$yaml.tmp" && mv "$yaml.tmp" "$yaml"
	elif [ -f "$yaml" ]; then
		printf '\nservices:\n  - %s\n' "$name" >> "$yaml"
	else
		printf 'services:\n  - %s\n' "$name" > "$yaml"
	fi

	# Live pickup + clear any stale disable marker from a previous life.
	mkdir -p /run/svc
	grep -qx "$name" /run/svc/enabled 2>/dev/null || echo "$name" >> /run/svc/enabled
	rm -f "/data/svc/disabled/$name" "/run/svc/disabled/$name" 2>/dev/null || true
	log "enabled $name — added to services: in zurvan.yaml; the supervisor starts it within a second"
}

cmd_remove() {
	need_data
	open_root
	name="$1"
	[ -d "$APPS/$name" ] || fail "$name is not installed"
	remove_links "$name"
	rm -f "/run/svc/$name.def"
	rm -rf "$APPS/$name"
	log "removed $name (state kept in $SRV/$name — delete that yourself if you mean it)"
}

cmd_list() {
	need_data
	found=0
	for man in "$APPS"/*/manifest.yaml; do
		[ -f "$man" ] || continue
		found=1
		printf '%s %s\n' \
			"$(yaml_scalar name "$man")" "$(yaml_scalar version "$man")"
	done
	[ "$found" = 1 ] || log "no packages installed"
}

cmd_dress() {
	# Rebuild every link from every manifest — called by rc.init each boot,
	# after /data mounts and before services start. Idempotent by nature.
	# (At boot the root is still writable; open_root is only needed for a
	# manual `zurvan-pkg dress` after the seal.)
	mountpoint -q /data 2>/dev/null || return 0
	open_root
	for man in "$APPS"/*/manifest.yaml; do
		[ -f "$man" ] || continue
		name="$(yaml_scalar name "$man")"
		plant_links "$name"
		export_service "$name"
		log "dressed $name"
	done
}

# --- dispatch -----------------------------------------------------------------------
usage() {
	echo "usage: zurvan-pkg install [--unsigned] <pkg.tar.gz> | remove <name> | enable <name> | list | dress" >&2
	exit 1
}
[ $# -ge 1 ] || usage
cmd="$1"; shift
case "$cmd" in
	install)
		unsigned=0
		if [ "${1:-}" = "--unsigned" ]; then unsigned=1; shift; fi
		[ $# -eq 1 ] || usage
		cmd_install "$1" "$unsigned" ;;
	remove)  [ $# -eq 1 ] || usage; cmd_remove "$1" ;;
	enable)  [ $# -eq 1 ] || usage; cmd_enable "$1" ;;
	list)    cmd_list ;;
	dress)   cmd_dress ;;
	*) usage ;;
esac
